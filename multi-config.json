{
  "comment": "Root-level credentials are the global default for every destination that does not override them.",
  "username_value": "admin",
  "password_value": "s3cret",
  "timeout": 60,
  "retry_count": 3,
  "retry_delay_ms": 1500,

  "destinations": [

    {
      "name": "ZABBIX",
      "tag": "zabbix",

      "comment_category": "Category-level selectors apply to every Zabbix URL unless overridden at URL level.",
      "username_selector": "#name",
