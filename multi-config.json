          "navigate_url":   "https://zabbix.staging.example.com/zabbix/zabbix.php?action=dashboard.view",

          "comment_url": "Staging uses different HTML field names — override selectors at URL level.",
          "username_selector": "#f_user_name",
          "password_selector": "#f_user_pw",
