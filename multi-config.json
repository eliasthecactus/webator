          "auth_done_url":  "https://zabbix.prod.example.com/zabbix/zabbix.php",
          "navigate_url":   "https://zabbix.prod.example.com/zabbix/zabbix.php?action=dashboard.view"
        },
        {
          "label":          "Zabbix Staging",
          "tag":            "zabbix-staging",
          "auth_start_url": "https://zabbix.staging.example.com/zabbix/",
